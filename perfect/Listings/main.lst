  43          void Buzzer_Time(unsigned int ms)   
  44          {
  45   1        unsigned int i;
  46   1          Buzzer = 1; // 初始置高，防止电平漂移
  47   1        for(i=0;i<ms*2;i++)
  48   1        {
  49   2          Buzzer=0;       // 低电平触发蜂鸣器发声
